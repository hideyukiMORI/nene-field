{
    "name": "hideyukimori/nene-field",
    "description": "NeNe Field — self-hosted daily report platform for Japan SMB, built on NENE2.",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": ">=8.4.1 <9.0",
        "hideyukimori/nene2": "^1.8.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^13.1",
        "robmorgan/phinx": "^0.16.11"
    },
    "autoload": {
        "psr-4": {
            "NeneField\\": "src/"
        },
        "files": [
            "src/bootstrap.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "NeneField\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse --memory-limit 512M",
        "cs": "php-cs-fixer fix --dry-run --diff --config=.php-cs-fixer.php",
        "cs:fix": "php-cs-fixer fix --config=.php-cs-fixer.php",
        "conformance": "php vendor/hideyukimori/nene2/tools/conformance.php --root=.",
        "migrations:status": "phinx status -c phinx.php",
        "migrations:migrate": "phinx migrate -c phinx.php",
        "migrations:rollback": "phinx rollback -c phinx.php",
        "migrations:seed": "phinx seed:run -c phinx.php",
        "check": [
            "@test",
            "@analyse",
            "@cs",
            "@conformance"
        ]
    }
}
