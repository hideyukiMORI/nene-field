# NeNe Field — local environment example. Copy to .env (never commit .env).

APP_ENV=local
APP_DEBUG=true
APP_NAME="NeNe Field"

# ── Tenant resolution (ADR 0013 / docs/development/multi-tenancy.md) ──
# single = one organization per install (Tier A); subdomain | path = multi-org (Tier B).
NENE_FIELD_TENANT_RESOLUTION=single
NENE_FIELD_ORG_SLUG=
NENE_FIELD_BASE_DOMAIN=localhost

# ── Database (wired with the domain endpoints) ──
# Tier A default is SQLite; Tier B uses MySQL.
DB_ADAPTER=sqlite

# ── Local host ports ("90 lane" — see README) ──
NENE_FIELD_PORT=9000
NENE_FIELD_PHPMYADMIN_PORT=9001
NENE_FIELD_MYSQL_PORT=3309
NENE_FIELD_FRONTEND_PORT=5190
