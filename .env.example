# NeNe Field — local environment example. Copy to .env (never commit .env).

APP_ENV=local
APP_DEBUG=true
APP_NAME="NeNe Field"

# ── Tenant resolution (ADR 0013 / docs/development/multi-tenancy.md) ──
# single = one organization per install (Tier A); subdomain | path = multi-org (Tier B).
NENE_FIELD_TENANT_RESOLUTION=single
NENE_FIELD_ORG_SLUG=
NENE_FIELD_BASE_DOMAIN=localhost

# ── Problem Details ──
PROBLEM_DETAILS_BASE_URL=https://nene-field.dev/problems/

# ── Auth ──
# Secret used to sign/verify local JWTs. REQUIRED in production (the app refuses to
# start auth with a dev fallback there). Generate a long random value.
NENE2_LOCAL_JWT_SECRET=
# Opt in to the framework's built-in development secret when NENE2_LOCAL_JWT_SECRET
# is unset. local/dev only — never set this in production (ignored there anyway).
NENE2_ALLOW_DEV_SECRET=1

# ── Attachments ──
# Filesystem root for uploaded attachment binaries (metadata stays in the DB).
# Defaults to {projectRoot}/var/attachments. Storage paths are never exposed in
# API responses; files are served through the authenticated download endpoint.
NENE_FIELD_STORAGE_PATH=

# ── Database ──
# Tier A default is SQLite (DB_NAME = file path without suffix, or ":memory:").
DB_ADAPTER=sqlite
DB_NAME=var/nene-field
# Tier B (MySQL): set DB_ADAPTER=mysql and the values below.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=nene_field
DB_PASSWORD=
DB_CHARSET=utf8mb4

# ── Local host ports ("92 lane" — see README) ──
NENE_FIELD_PORT=9200
NENE_FIELD_PHPMYADMIN_PORT=9201
NENE_FIELD_MYSQL_PORT=3309
NENE_FIELD_FRONTEND_PORT=5192
